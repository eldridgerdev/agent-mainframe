{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "[ -n \"$AMF_SESSION\" ] && mkdir -p /tmp/amf-thinking && touch \"/tmp/amf-thinking/$AMF_SESSION\" || true",
            "type": "command"
          },
          {
            "command": "/home/eldridger/.config/amf/clear-notify.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "[ -n \"$AMF_SESSION\" ] && rm -f \"/tmp/amf-thinking/$AMF_SESSION\" || true",
            "type": "command"
          },
          {
            "command": "/home/eldridger/.config/amf/notify.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "/home/eldridger/.config/amf/save-prompt.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}