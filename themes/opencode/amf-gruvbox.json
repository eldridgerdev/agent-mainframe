{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg":          "#282828",
    "bg1":         "#3c3836",
    "bg2":         "#504945",
    "bg3":         "#665c54",
    "bg4":         "#7c6f64",
    "fg":          "#ebdbb2",
    "fg2":         "#d5c4a1",
    "fg3":         "#bdae93",
    "fg4":         "#a89984",
    "gray":        "#928374",
    "red":         "#cc241d",
    "green":       "#98971a",
    "yellow":      "#d79921",
    "blue":        "#458588",
    "purple":      "#b16286",
    "aqua":        "#689d6a",
    "orange":      "#d65d0e",
    "bright_red":  "#fb4934",
    "bright_green":"#b8bb26",
    "bright_yellow":"#fabd2f",
    "bright_blue": "#83a598",
    "bright_purple":"#d3869b",
    "bright_aqua": "#8ec07c",
    "bright_orange":"#fe8019",
    "diff_add":    "#3c3836",
    "diff_delete": "#504945"
  },
  "theme": {
    "primary": {
      "dark": "bright_blue",
      "light": "blue"
    },
    "secondary": {
      "dark": "bright_purple",
      "light": "purple"
    },
    "accent": {
      "dark": "bright_aqua",
      "light": "aqua"
    },
    "error": {
      "dark": "bright_red",
      "light": "red"
    },
    "warning": {
      "dark": "bright_yellow",
      "light": "yellow"
    },
    "success": {
      "dark": "bright_green",
      "light": "green"
    },
    "info": {
      "dark": "bright_aqua",
      "light": "aqua"
    },
    "text": {
      "dark": "#ebdbb2",
      "light": "#282828"
    },
    "textMuted": {
      "dark": "#a89984",
      "light": "#665c54"
    },
    "background": {
      "dark": "bg",
      "light": "#fbf1c7"
    },
    "backgroundPanel": {
      "dark": "bg1",
      "light": "#f2e5bc"
    },
    "backgroundElement": {
      "dark": "bg2",
      "light": "#ebdbb2"
    },
    "border": {
      "dark": "bg3",
      "light": "fg3"
    },
    "borderActive": {
      "dark": "bright_blue",
      "light": "blue"
    },
    "borderSubtle": {
      "dark": "bg2",
      "light": "fg4"
    },
    "diffAdded": {
      "dark": "bright_green",
      "light": "green"
    },
    "diffRemoved": {
      "dark": "bright_red",
      "light": "red"
    },
    "diffContext": {
      "dark": "fg4",
      "light": "fg3"
    },
    "diffHunkHeader": {
      "dark": "bright_yellow",
      "light": "yellow"
    },
    "diffHighlightAdded": {
      "dark": "bright_green",
      "light": "green"
    },
    "diffHighlightRemoved": {
      "dark": "bright_red",
      "light": "red"
    },
    "diffAddedBg": {
      "dark": "diff_add",
      "light": "diff_add"
    },
    "diffRemovedBg": {
      "dark": "diff_delete",
      "light": "diff_delete"
    },
    "diffContextBg": {
      "dark": "bg1",
      "light": "#f2e5bc"
    },
    "diffLineNumber": {
      "dark": "bg3",
      "light": "fg3"
    },
    "diffAddedLineNumberBg": {
      "dark": "diff_add",
      "light": "diff_add"
    },
    "diffRemovedLineNumberBg": {
      "dark": "diff_delete",
      "light": "diff_delete"
    },
    "markdownText": {
      "dark": "#ebdbb2",
      "light": "#282828"
    },
    "markdownHeading": {
      "dark": "bright_yellow",
      "light": "yellow"
    },
    "markdownLink": {
      "dark": "bright_blue",
      "light": "blue"
    },
    "markdownLinkText": {
      "dark": "bright_aqua",
      "light": "aqua"
    },
    "markdownCode": {
      "dark": "bright_green",
      "light": "green"
    },
    "markdownBlockQuote": {
      "dark": "fg4",
      "light": "fg3"
    },
    "markdownEmph": {
      "dark": "bright_orange",
      "light": "orange"
    },
    "markdownStrong": {
      "dark": "bright_yellow",
      "light": "yellow"
    },
    "markdownHorizontalRule": {
      "dark": "bg3",
      "light": "fg3"
    },
    "markdownListItem": {
      "dark": "bright_blue",
      "light": "blue"
    },
    "markdownListEnumeration": {
      "dark": "bright_aqua",
      "light": "aqua"
    },
    "markdownImage": {
      "dark": "bright_purple",
      "light": "purple"
    },
    "markdownImageText": {
      "dark": "bright_aqua",
      "light": "aqua"
    },
    "markdownCodeBlock": {
      "dark": "bg1",
      "light": "#f2e5bc"
    },
    "syntaxComment": {
      "dark": "gray",
      "light": "bg3"
    },
    "syntaxKeyword": {
      "dark": "bright_red",
      "light": "red"
    },
    "syntaxFunction": {
      "dark": "bright_green",
      "light": "green"
    },
    "syntaxVariable": {
      "dark": "bright_blue",
      "light": "blue"
    },
    "syntaxString": {
      "dark": "bright_green",
      "light": "green"
    },
    "syntaxNumber": {
      "dark": "bright_purple",
      "light": "purple"
    },
    "syntaxType": {
      "dark": "bright_yellow",
      "light": "yellow"
    },
    "syntaxOperator": {
      "dark": "bright_aqua",
      "light": "aqua"
    },
    "syntaxPunctuation": {
      "dark": "#ebdbb2",
      "light": "#282828"
    }
  }
}
